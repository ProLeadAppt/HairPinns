# API routes - must come before SPA catch-all
/api/checkout  /.netlify/functions/checkout  200
/api/indexnow  /.netlify/functions/indexnow  200
/cart/c/*  https://femtat-zu.myshopify.com/cart/c/:splat  200
/cart      https://femtat-zu.myshopify.com/cart            200

# Static txt / discovery files - served from the repo root, NOT the SPA shell.
# Without these explicit rules Netlify's SPA fallback would serve index.html
# (text/html, 100 KB) for every request below, which makes /llm.txt and
# /ai.txt unusable to LLM crawlers that expect text/plain.
/llm.txt         /llm.txt          200
/llms.txt        /llms.txt         200
/llms-full.txt   /llms-full.txt    200
/ai.txt          /ai.txt           200
/humans.txt      /humans.txt       200
/.well-known/security.txt  /.well-known/security.txt  200